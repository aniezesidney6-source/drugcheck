# ─────────────────────────────────────────────────────────────────────────────
# DrugCheck Nigeria — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# The port the Express server will listen on.
# Render/Railway will automatically set PORT — leave blank to let them manage it.
PORT=3000

# ── Twilio Credentials ────────────────────────────────────────────────────────
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio sandbox WhatsApp number (from the Twilio Sandbox settings)
# Format: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Optional: Supabase (for future production database) ───────────────────────
# When you're ready to replace the JSON mock database with Supabase,
# uncomment these and update services/drugLookup.js to use the Supabase client.
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Optional: Environment label ───────────────────────────────────────────────
NODE_ENV=development
